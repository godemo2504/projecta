Bash
#!/bin/bash

NODES=("node1" "node2" "node3")

for NODE in "${NODES[@]}"; do
  ping -c 2 $NODE > /dev/null
  if [[ $? -ne 0 ]]; then
    echo "❌ Network issue with $NODE"
  else
    echo "✅ $NODE reachable"
  fi
done
