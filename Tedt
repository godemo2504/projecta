Bash
#!/bin/bash

echo "===== FULL HEALTH CHECK ====="

# Cluster
pvecm status | grep Quorate

# Hardware
ipmitool sensor | grep -E "Temp|Fan|Power"

# Disks
for disk in /dev/sd?; do
  smartctl -H $disk | grep -v PASSED && echo "Disk issue $disk"
done

# Network
ip -s link | grep -A5 "eth"

echo "================================"
