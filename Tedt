⚙️ 2. Script Linux (sans iDRAC)
👉 Script complet de health physique :
Bash
#!/bin/bash

echo "===== HARDWARE HEALTH ====="

echo -e "\n--- CPU Temp ---"
sensors

echo -e "\n--- Memory Errors ---"
dmesg | grep -i ecc

echo -e "\n--- Disk Health ---"
for disk in /dev/sd?; do
  echo "Disk: $disk"
  smartctl -H $disk
done

echo -e "\n--- RAID Status ---"
# MegaRAID
megacli -LDInfo -Lall -aALL 2>/dev/null

# HP Smart Array
hpacucli ctrl all show status 2>/dev/null

echo -e "\n--- Network Errors ---"
ip -s link

echo -e "\n--- PSU / Fans (if supported) ---"
ipmitool sensor

echo "================================"
