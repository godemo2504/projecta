🧾 1. Script principal (health check cluster)
👉 Script Bash global à exécuter sur un node (ou via SSH sur les 3)
Bash
#!/bin/bash

echo "===== PROXMOX CLUSTER HEALTH ====="
date

echo -e "\n--- Cluster Status ---"
pvecm status

echo -e "\n--- Nodes Status ---"
pvecm nodes

echo -e "\n--- HA Status ---"
ha-manager status

echo -e "\n--- VM Status ---"
qm list

echo -e "\n--- Resources ---"
echo "CPU Load:"
uptime

echo -e "\nMemory:"
free -h

echo -e "\nDisk:"
df -h

echo -e "\n--- Corosync ---"
systemctl status corosync | grep Active

echo -e "\n--- pve-cluster ---"
systemctl status pve-cluster | grep Active

echo "=================================="
